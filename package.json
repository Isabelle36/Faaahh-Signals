{
  "name": "faaahhh-signals",
  "publisher": "AlfiNikhat",
  "displayName": "Faaahhh Signals",
"description": "Plays the iconic FAAAAH sound (and 10 other meme sounds) whenever you run a wrong command in the terminal. Never silently fail again. 🔊",
"keywords": ["sound", "terminal", "error", "faah", "meme", "fun"],
  "version": "0.0.2",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
  "type": "git",
  "url": "https://github.com/Isabelle36/Faaahh-Signals"
},
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [ "onStartupFinished" ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faaahhh.pickSound",
        "title": "Faaahhh: Pick Sound"
      }
    ],
    "configuration": {
      "title": "Faaahhh Signals",
      "properties": {
     "faaahhh.sound": {
  "type": "string",
  "default": "Faahh",
  "enum": [
    "Faahh",
    "AHH-anime-girl",
    "and-his-name-is-john-cena",
    "cid",
    "faah-but-bad-one",
    "Gawk-Gawk",
    "Hell-nah-bruh",
    "Khatam-Bye-Bye",
    "laughing-dog-meme",
    "Shocked",
    "yooi"
  ],
  "enumDescriptions": [
    "😤 The classic Faaahh",
    "😱 AHH Anime Girl",
    "🎺 AND HIS NAME IS JOHN CENA",
    "🕵️ CID",
    "😤 Faah But Bad One",
    "💀 Gawk Gawk",
    "🙅 Hell Nah Bruh",
    "👋 Khatam Bye Bye",
    "🐶 Laughing Dog Meme",
    "😲 Shocked",
    "✨ Yooi"
  ],
  "description": "Choose your error sound"
},
        "faaahhh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable error sounds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/play-sound": "^1.1.2",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@types/sound-play": "^1.1.3",
    "play-sound": "^1.1.6",
    "sound-play": "^1.1.0"
  }
}
